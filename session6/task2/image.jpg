  /* E. Smaller trust icons row */
  .fcpack__trustrow { gap: 6px !important; margin: 10px 0 !important; }
  .fcpack__trustcell { padding: 10px 6px 9px !important; border-radius: 10px !important; }
  .fcpack__trusticon { width: 32px !important; height: 32px !important; border-radius: 8px !important; margin: 0 auto 6px !important; }
  .fcpack__trusticon svg { width: 18px !important; height: 18px !important; }
  .fcpack__trustlabel { font-size: 11px !important; line-height: 1.15 !important; }
  .fcpack__trustsub { font-size: 9.5px !important; margin-top: 2px !important; }

  /* Tighter spacing between major blocks */
  .fcpack__priceblock { margin-bottom: 10px !important; }
  .fcpack__priceblock-now { font-size: 24px !important; }
  .fcpack__trusted { padding: 9px 12px !important; margin-bottom: 12px !important; }
  .fcpack__hero, .fcpack__savebar { padding: 8px 12px !important; margin-bottom: 12px !important; font-size: 12.5px !important; }
  .fcpack__label, .fcpack__cardslabel, .fcpack__choose-label { margin: 0 0 10px !important; font-size: 12.5px !important; }
  .fcpack__cards { gap: 10px !important; }
  .fcpack__nudge { font-size: 12px !important; margin: 10px 0 !important; }
  .fcpack__urgency { font-size: 12px !important; margin: 8px 0 12px !important; }
  .fcpack__toast { padding: 8px 12px !important; font-size: 12px !important; }
}
/* === FINAL VARIANT CARD LAYOUT — 2-row clean grid (universal) === */
.fcpack .fcpack__card{
  align-items:center !important;
  gap:10px !important;
}
.fcpack .fcpack__radio{flex:0 0 18px !important}

.fcpack .fcpack__body{
  flex:1 1 auto !important;
  min-width:0 !important;
  display:flex !important;
  flex-direction:column !important;
  gap:4px !important;
}
.fcpack .fcpack__name{
  display:flex !important;
  flex-direction:row !important;
  flex-wrap:wrap !important;
  align-items:center !important;
  gap:5px 7px !important;
  font-size:13.5px !important;
  line-height:1.2 !important;
  min-width:0 !important;
}
.fcpack .fcpack__name > span{
  flex:0 0 auto !important;
  white-space:normal !important;
  overflow:visible !important;
  text-overflow:clip !important;
