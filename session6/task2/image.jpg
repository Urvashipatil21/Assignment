<style>
  /* BLUE FULL WIDTH BACKGROUND */
  #shopify-section-template--24445711319063__custom_liquid_6qBbXk {
    background: #0ea5e9 !important;
    padding: 0;
    margin: 0;
  }

  .insta-wrapper {
    max-width: 1200px;
    margin: auto;
    padding: 16px 0 20px;
  }

  .insta-title {
    text-align: center;
    color: #ffffff;
    font-size: 22px;   /* smaller heading */
    font-weight: 800;
    margin-bottom: 8px;
  }

  /* SLIDER */
  .insta-slider {
    position: relative;
    width: 100%;
  }

  .insta-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 10px;           /* only 10px side padding */
    scrollbar-width: none;
  }
  .insta-track::-webkit-scrollbar {
    display: none;
  }

  .insta-card {
    flex: 0 0 60%;
    max-width: 260px;
    scroll-snap-align: center;
    text-decoration: none;
  }

  .insta-media {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    aspect-ratio: 9/16;
    background: #000;
  }

  .insta-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* USER BADGE */
  .insta-userbox {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(0,0,0,0.65);
    padding: 4px 10px;
    border-radius: 30px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .insta-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
  }

  .insta-username {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
  }

  /* ARROWS */
  .insta-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    background: rgba(0,0,0,0.65);
    color: #fff;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    font-size: 22px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 20;
  }

  .insta-prev { left: 5px; }
  .insta-next { right: 5px; }

  /* MOBILE BEHAVIOUR */
  @media (max-width: 768px) {
    .insta-card {
      flex-basis: 80%;
    }

    /* When ONLY ONE item: center it */
    .insta-track--single {
      justify-content: center;
    }
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const root = document.getElementById("insta-wrapper-7642003210263");
  if (!root) return;

  const track = root.querySelector(".insta-track");
  if (!track) return;

  const arrows = root.querySelectorAll(".insta-arrow");

  function getSlideWidth() {
    const first = track.querySelector(".insta-card");
    return first ? first.getBoundingClientRect().width + 20 : 300;
  }

  arrows.forEach(btn => {
    btn.addEventListener("click", () => {
      const dir = Number(btn.dataset.direction);
      track.scrollBy({ left: getSlideWidth() * dir, behavior: "smooth" });
    });
  });
});
</script>
  </div>
</div>


