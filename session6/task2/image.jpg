  }
  .fcpack__now { font-size: 14.5px !important; }
  .fcpack__strk, .fcpack__strk s, .fcpack__card s, .fcpack__card del { font-size: 12px !important; }
  .fcpack__pu, .fcpack__unitpill { font-size: 10.5px !important; padding: 2px 6px !important; }
  .fcpack__badge { font-size: 9px !important; padding: 2px 6px !important; }

  /* D. Smaller delivery timeline */
  .fcpack__delivery { padding: 12px 12px 16px !important; margin: 10px 0 8px !important; }
  .fcpack__delivery-head { margin-bottom: 12px !important; }
  .fcpack__delivery-eyebrow { font-size: 10px !important; letter-spacing: .15em !important; }
  .fcpack__delivery-pill { font-size: 10.5px !important; padding: 4px 9px 4px 8px !important; }
  .fcpack__delivery-pill svg { width: 12px !important; height: 12px !important; }
  .fcpack__tlrow { min-height: 64px !important; padding: 0 6px !important; }
  .fcpack__tlcircle { width: 26px !important; height: 26px !important; }
  .fcpack__tlcircle svg { width: 12px !important; height: 12px !important; }
  .fcpack__tllabel { font-size: 11px !important; margin-top: 4px !important; }
  .fcpack__tlsub { font-size: 9.5px !important; }
  .fcpack__tltrack-base, .fcpack__tltrack-fill { top: 14px !important; height: 3px !important; }
  .fcpack__tltruck { width: 24px !important; height: 24px !important; top: 1px !important; }
