}

.fcpack .fcpack__price{
  display:grid !important;
  grid-template-columns:auto auto !important;
  grid-template-rows:auto auto !important;
  align-items:baseline !important;
  justify-content:end !important;
  justify-items:end !important;
  column-gap:5px !important;
  row-gap:2px !important;
  flex:0 0 auto !important;
  max-width:48% !important;
  text-align:right !important;
}
.fcpack .fcpack__price .fcpack__now{
  grid-column:1 / -1 !important;
  grid-row:1 !important;
  justify-self:end !important;
  font-size:15px !important;font-weight:800 !important;
  text-align:right !important;
}
.fcpack .fcpack__price .fcpack__strk{
  grid-column:1 !important;
  grid-row:2 !important;
  justify-self:end !important;
  align-self:baseline !important;
  font-size:12px !important;
}
.fcpack .fcpack__price .fcpack__pu,
.fcpack .fcpack__price .fcpack__pu--mute{
  grid-column:2 !important;
  grid-row:2 !important;
  justify-self:end !important;
  align-self:baseline !important;
  font-size:10.5px !important;
  padding:2px 6px !important;
  max-width:max-content !important;
  display:inline-block !important;
}
/* === end final layout === */
/* Enable swipe gesture on main product image gallery */
.product__media-list,
.product__media-item,
.product__media,
.media-gallery,
product-media-gallery {
  touch-action: pan-x !important;
}
.product__media img,
.product__media-item img,
product-media-gallery img,
.product__modal-opener img {
  pointer-events: none !important;
}

/* Variant name wrap on overflow */
.fcpack .fcpack__body{
  min-width: 0 !important;
}
.fcpack .fcpack__name{
  min-width: 0 !important;
  max-width: 100% !important;
  flex-wrap: wrap !important;
}
.fcpack .fcpack__name > span{
  flex: 0 1 auto !important;
  white-space: normal !important;
  overflow: visible !important;
  text-overflow: clip !important;
  word-break: break-word !important;
  overflow-wrap: anywhere !important;
  margin-right: 0 !important;
  min-width: 0 !important;
  max-width: 100% !important;
}


/* Cap main image height ~10% smaller than viewport-determined size */
.product__media,
.media-gallery,
product-media-gallery {
  max-height: 44vh !important;
}
.product__media-item,
.media-gallery__media,
product-media-gallery .media,
.product__modal-opener {
  max-height: 44vh !important;
  height: 44vh !important;
  overflow: hidden !important;
}
.product__media img,
.product__media-item img,
product-media-gallery img,
.product__modal-opener img {
  width: 100% !important;
  height: 44vh !important;
  max-height: 44vh !important;
  max-width: 100% !important;
  object-fit: cover !important;
  object-position: center !important;
  display: block !important;
  margin: 0 !important;
}
/* Kill horizontal page swipe — minimal version */
body {
  overflow-x: hidden !important;
}
.product__media,
.media-gallery,
product-media-gallery {
  overflow-x: hidden !important;
}
.product__media-item {
  touch-action: pan-x !important;
}
.product__media-list {
  touch-action: pan-y !important;
}
/* Only the visible gallery viewport gets pan-x — not the slider track */
.product__media,
.media-gallery,
product-media-gallery,
.product__media-item {
  touch-action: pan-x !important;
}
.product__media-list {
  touch-action: pan-y !important;
}
/* Hide scrollbar visually — scrolling still works */
html, body {
  scrollbar-width: none !important; /* Firefox */
  -ms-overflow-style: none !important; /* IE/Edge */
}
html::-webkit-scrollbar,
body::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
}
/* Desktop: bigger image — fills the column properly */
@media (min-width: 750px) {
  .product__media,
  .media-gallery,
  product-media-gallery {
    max-height: 75vh !important;
  }
  .product__media-item,
  .media-gallery__media,
  product-media-gallery .media,
  .product__modal-opener {
    max-height: 75vh !important;
    height: 75vh !important;
  }
  .product__media img,
  .product__media-item img,
  product-media-gallery img,
  .product__modal-opener img {
    width: 100% !important;
    height: 75vh !important;
    max-height: 75vh !important;
    max-width: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
  }
}

</style>
<script>
(function(){
  // Programmatic swipe handler for the product media slider
  function initSwipe(){
    var galleries = document.querySelectorAll('media-gallery, product-media-gallery, .product__media-list, [id^="GalleryViewer-"]');
    galleries.forEach(function(g){
      if (g.dataset.fcSwipeInit) return;
      g.dataset.fcSwipeInit = '1';
      var startX = 0, startY = 0, touchActive = false;
      g.addEventListener('touchstart', function(e){
        if (!e.touches || !e.touches[0]) return;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: true });
      g.addEventListener('touchend', function(e){
        if (!touchActive) return;
        touchActive = false;
        if (!e.changedTouches || !e.changedTouches[0]) return;
        var dx = e.changedTouches[0].clientX - startX;
        var dy = e.changedTouches[0].clientY - startY;
        if (Math.abs(dx) < 40 || Math.abs(dx) < Math.abs(dy)) return;
        var root = g.closest('media-gallery, product-media-gallery') || g;
        var nextBtn = root.querySelector('.slider-button--next, .splide__arrow--next, button[name="next"]');
        var prevBtn = root.querySelector('.slider-button--prev, .splide__arrow--prev, button[name="previous"]');
        if (dx < 0 && nextBtn) nextBtn.click();
        else if (dx > 0 && prevBtn) prevBtn.click();
      }, { passive: true });
    });
  }
  if (document.readyState === 'complete') initSwipe();
  else window.addEventListener('load', initSwipe);
  setTimeout(initSwipe, 1500);
  setTimeout(initSwipe, 3500);
})();
</script><script>
(function(){
  var root = document.querySelector('[data-fcpack]');
  if (!root || root.dataset.fcInit) return;
  root.dataset.fcInit = '1';

  if (!document.body.classList.contains('fcpack-pad-applied')){
    document.body.classList.add('fcpack-pad-applied');
  }

  var cards = root.querySelectorAll('[data-fc-card]');
  var hero = root.querySelector('[data-fc-hero]');
  var heroAmt = root.querySelector('[data-fc-hero-amt]');
  var fill = root.querySelector('[data-fc-fill]');
  var nudge = root.querySelector('[data-fc-nudge]');
  var stockEl = root.querySelector('[data-fc-stock]');
  var toast = root.querySelector('[data-fc-toast]');
  var toastTx = root.querySelector('[data-fc-toast-tx]');
  var ctaBtn = root.querySelector('[data-fc-buy]');
  var total = parseInt(root.getAttribute('data-total') || cards.length, 10);
  var unitWord = root.getAttribute('data-unit') || 'pc';
  var bestPerUnit = nudge ? parseInt(nudge.getAttribute('data-best-per-unit') || 0, 10) : 0;

  var sticky = document.querySelector('[data-fc-sticky]');
  var sPriceEl = sticky ? sticky.querySelector('[data-fc-sticky-price]') : null;
  var sStrkEl = sticky ? sticky.querySelector('[data-fc-sticky-strk]') : null;
  var sSaveEl = sticky ? sticky.querySelector('[data-fc-sticky-save]') : null;
  var sBuyBtn = sticky ? sticky.querySelector('[data-fc-sticky-buy]') : null;

  var confCols = ['#B5714C','#C0922E','#CD9069','#E0BC5A','#6A5B4F','#DD7136'];

  function inr(n){ return '₹' + Math.round(n).toLocaleString('en-IN'); }

  /* ===== Web Audio (verbatim from sound-picker) ===== */
  var soundOn = true;
  var actx = null;
  function getCtx(){
    if (!actx){
      try { actx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e){}
    }
    if (actx && actx.state === 'suspended'){
      try { actx.resume(); } catch(e){}
    }
    return actx;
  }
  ['pointerdown','touchstart','keydown','scroll'].forEach(function(ev){
    window.addEventListener(ev, function unl(){ getCtx(); window.removeEventListener(ev, unl); }, { once:true, passive:true });
  });
  function tone(f, start, dur, type, vol){
    var c = getCtx(); if (!c) return;
    var o = c.createOscillator(); var g = c.createGain();
    o.type = type || 'triangle';
    o.frequency.value = f;
    o.connect(g); g.connect(c.destination);
    g.gain.setValueAtTime(0, start);
    g.gain.linearRampToValueAtTime(vol, start + 0.015);
    g.gain.exponentialRampToValueAtTime(0.0001, start + dur);
    o.start(start); o.stop(start + dur + 0.03);
  }
  function chime(big){
    var c = getCtx(); if (!c) return;
    var t = c.currentTime;
    [523.25, 659.25, 783.99].concat(big ? [1046.5] : []).forEach(function(f, i){
      tone(f, t + i * 0.085, 0.22, 'triangle', 0.13);
    });
    if (big){
      tone(1318.5, t + 0.30, 0.18, 'sine', 0.09);
      tone(1567.98, t + 0.40, 0.22, 'sine', 0.08);
      tone(2093, t + 0.50, 0.28, 'sine', 0.06);
    }
  }
  function playReward(level){
    if (!soundOn) return;
    if (level === 0){
      var c = getCtx(); if (!c) return;
      var t = c.currentTime;
      tone(300, t, 0.13, 'sine', 0.05);
      tone(220, t + 0.08, 0.16, 'sine', 0.05);
      return;
    }
    chime(level === 2);
  }

  /* ===== Confetti ===== */
      /* ===== Confetti ===== */
function confetti(card, big){

  const colors = [
  '#FF3B30', // red
  '#FF9500', // orange
  '#FFD60A', // yellow
  '#34C759', // green
  '#0A84FF', // blue
  '#BF5AF2', // purple
  '#FF2D55', // pink
  '#FFFFFF'  // white
];

  const count = big ? 25 : 15;

  card.style.position = 'relative';

  for(let i = 0; i < count; i++){

    const piece = document.createElement('span');

    piece.className = 'fcpack__conf';

    piece.style.background =
      colors[Math.floor(Math.random() * colors.length)];

    piece.style.width =
  (6 + Math.random()*10) + 'px';

piece.style.height =
  (10 + Math.random()*14) + 'px';

    /* Start from radio button area */
    piece.style.left = '50%';
    piece.style.top = '50%';
    piece.style.transform = 'translate(-50%, -50%)';
    card.appendChild(piece);

    const angle = Math.random() * Math.PI * 2;

const distance =
  50 + Math.random() * 90;

const x =
  Math.cos(angle) * distance;

const y =
  Math.sin(angle) * distance;
    piece.style.boxShadow ='none';
    piece.animate(
[
  {
    transform:'translate(0,0) rotate(0deg)',
    opacity:1
  },
  {
    transform:`translate(${x}px,${y}px) rotate(${720*Math.random()}deg)`,
    opacity:0
  }
],
{
  duration:1600,
  
  easing:'cubic-bezier(.16,1,.3,1)'
}
);

    setTimeout(() => {
      piece.remove();
    }, 1600);
  }
}

  /* ===== Main price count-up ===== */
  var lastCents = null;
  var animFrame = null;
  cards.forEach(function(c){
    if (c.classList.contains('is-sel')){
      lastCents = parseInt(c.getAttribute('data-price') || 0, 10);
    }
  });
  function findMainPriceEl(){
    var sel = [
      '[data-fc-main-price]',
      '.price__regular .price-item--regular',
      '.price .price-item--regular',
      '.product__price .price-item--regular',
      '[data-vp-now]'
    ];
    for (var i = 0; i < sel.length; i++){
      var els = document.querySelectorAll(sel[i]);
      for (var j = 0; j < els.length; j++){
        if (els[j].offsetParent !== null) return els[j];
      }
    }
    return null;
  }
  function fmtMoney(rupees){
    return '₹' + Math.round(rupees).toLocaleString('en-IN') + '.00';
  }
  function animateMainPrice(fromC, toC){
    if (!fromC || !toC || fromC === toC) return;
    var target = findMainPriceEl();
    var fromVal = fromC / 100, toVal = toC / 100;
    var start = performance.now();
    if (animFrame) cancelAnimationFrame(animFrame);
    function step(now){
      var p = Math.min((now - start) / 600, 1);
      var eased = p < 0.5 ? 2*p*p : 1 - Math.pow(-2*p + 2, 2)/2;
      var cur = fromVal + (toVal - fromVal) * eased;
      var txt = fmtMoney(cur);
      if (target) target.textContent = txt;
      if (sPriceEl) sPriceEl.textContent = txt;
      if (p < 1){
        animFrame = requestAnimationFrame(step);
      } else {
        animFrame = null;
        var finalTxt = fmtMoney(toVal);
        if (target) target.textContent = finalTxt;
        if (sPriceEl) sPriceEl.textContent = finalTxt;
            /* Update strikethrough + SAVE % pill from active card's baseline math */
            try {
              var activeCard = null;
              cards.forEach(function(c){ if (c.classList.contains('is-sel')) activeCard = c; });
              if (activeCard){
                var pb = root.querySelector('[data-fc-priceblock]');
                if (pb){
                  var wasEl = pb.querySelector('[data-fc-priceblock-was]');
                  var saveEl = pb.querySelector('[data-fc-priceblock-save]');
                  var wcCents = parseInt(activeCard.getAttribute('data-would-cost') || 0, 10);
                  var prCents = parseInt(activeCard.getAttribute('data-price') || 0, 10);
                  var pct = parseInt(activeCard.getAttribute('data-savings-pct') || 0, 10);
                  if (wasEl) {
                    if (wcCents > prCents) {
                      wasEl.textContent = '₹' + Math.round(wcCents/100).toLocaleString('en-IN');
                      wasEl.style.display = '';
                    } else { wasEl.style.display = 'none'; }
                  }
                  if (saveEl) {
                    if (pct > 0) { saveEl.textContent = 'SAVE ' + pct + '%'; saveEl.style.display = ''; }
                    else { saveEl.style.display = 'none'; }
                  }
                }
              }
            } catch(e){}
      }
    }
    animFrame = requestAnimationFrame(step);
  }

  /* ===== Refresh visuals ===== */
  function refresh(playFx){
    var active = null;
    cards.forEach(function(c){ if (c.classList.contains('is-sel')) active = c; });
    if (!active) active = cards[0];
    cards.forEach(function(c){
      var sel = c === active;
      c.classList.toggle('is-sel', sel);
      c.setAttribute('aria-checked', sel ? 'true' : 'false');
    });
    if (!active) return;

    var idx = parseInt(active.getAttribute('data-idx') || 0, 10);
    var savings = parseInt(active.getAttribute('data-savings') || 0, 10) / 100;
    var wouldCost = parseInt(active.getAttribute('data-would-cost') || 0, 10) / 100;
    var price = parseInt(active.getAttribute('data-price') || 0, 10) / 100;
    var perUnit = parseInt(active.getAttribute('data-per-unit') || 0, 10) / 100;
    var stock = parseInt(active.getAttribute('data-stock-left') || 0, 10);

    /* Hero */
    if (hero && heroAmt){
      if (savings > 0){
        heroAmt.textContent = inr(savings);
        hero.style.display = 'flex';
      } else {
        hero.style.display = 'none';
      }
    }

    /* Progress bar */
    if (fill && total > 1){
      var pct;
      if (idx === 0) pct = 12;
      else if (idx === total - 1) pct = 100;
      else pct = 12 + ((idx / (total - 1)) * 88);
      fill.style.width = pct + '%';
    }

    /* Nudge */
    if (nudge){
      if (idx === total - 1){
        nudge.innerHTML = 'Lowest price per ' + unitWord + ' unlocked &mdash; <b>best deal here</b>';
      } else if (idx === 0){
        var nextCard = cards[1];
        if (nextCard){
          var nextPrice = parseInt(nextCard.getAttribute('data-price'),10) / 100;
          var nextPU = parseInt(nextCard.getAttribute('data-per-unit'),10) / 100;
          var diff = nextPrice - price;
          nudge.innerHTML = 'Costliest per ' + unitWord + '. Add <b>' + (parseInt(nextCard.getAttribute('data-pack-size'),10) - parseInt(active.getAttribute('data-pack-size'),10)) + '</b> more &mdash; save <b>' + inr(diff > 0 ? (diff) : 0) + '</b>';
        } else {
          nudge.innerHTML = '';
        }
      } else {
        var prevCard = cards[idx - 1];
        var nextCard = cards[idx + 1];
        if (nextCard){
          var diff2 = (parseInt(nextCard.getAttribute('data-price'),10) - parseInt(active.getAttribute('data-price'),10)) / 100;
          var addMore = parseInt(nextCard.getAttribute('data-pack-size'),10) - parseInt(active.getAttribute('data-pack-size'),10);
          nudge.innerHTML = 'Add <b>' + addMore + '</b> more &mdash; save another <b>' + inr(diff2 > 0 ? diff2 : 0) + '</b>';
        } else {
          nudge.innerHTML = 'You’re at the best <b>₹' + bestPerUnit + '/' + unitWord + '</b> rate';
        }
      }
    }

    /* Stock urgency */
    if (stockEl) stockEl.textContent = stock;

    /* Sticky bar */
    if (sticky){
      if (sPriceEl && !animFrame) sPriceEl.textContent = fmtMoney(price);
      if (sStrkEl){
        if (wouldCost > price){ sStrkEl.textContent = inr(wouldCost); }
        else { sStrkEl.textContent = ''; }
      }
      if (sSaveEl){
        if (savings > 0){ sSaveEl.textContent = 'You save ' + inr(savings); }
        else { sSaveEl.textContent = ''; }
      }
    }

    if (playFx){
      confetti(active, idx === total - 1);
    }
  }

  /* ===== Click handler ===== */
  function selectShopifyVariant(variantId){
    /* Try to set the native variant input/selector */
    var inputs = document.querySelectorAll('input[name="id"]');
    inputs.forEach(function(i){
      if (i.value !== String(variantId)){
        i.value = variantId;
        i.dispatchEvent(new Event('change', { bubbles:true }));
      }
    });
    var selects = document.querySelectorAll('select[name="id"]');
    selects.forEach(function(s){
      if (s.value !== String(variantId)){
        s.value = variantId;
        s.dispatchEvent(new Event('change', { bubbles:true }));
      }
    });
  }

  cards.forEach(function(card){
    card.addEventListener('click', function(){
      if (card.classList.contains('is-soldout')) return;
      var wasSel = card.classList.contains('is-sel');
      var newCents = parseInt(card.getAttribute('data-price') || 0, 10);
      var oldCents = lastCents;
      lastCents = newCents;

      /* CRITICAL: set is-sel BEFORE refresh so refresh() picks the clicked card */
      cards.forEach(function(c){ c.classList.remove('is-sel'); c.setAttribute('aria-checked','false'); });
      card.classList.add('is-sel');

card.classList.remove('fcpack-pop');

void card.offsetWidth;

card.classList.add('fcpack-pop');
      card.setAttribute('aria-checked','true');

      /* Sound — fire & forget */
      try {
        var clickedIdx = parseInt(card.getAttribute('data-idx') || 0, 10);
        var soundLevel;
        if (clickedIdx === 0) soundLevel = 0;
        else if (clickedIdx === total - 1) soundLevel = 2;
        else soundLevel = 1;
        playReward(soundLevel);
      } catch(eSound){}

      /* Variant selection — critical for cart */
      try {
        var vid = card.getAttribute('data-variant-id');
        if (vid) selectShopifyVariant(vid);
      } catch(eVar){}

      /* Refresh UI + animations — non-critical */
      setTimeout(function(){
        try { refresh(!wasSel); } catch(eRef){}
        try {
          if (oldCents && oldCents !== newCents){
            animateMainPrice(oldCents, newCents);
          }
        } catch(eAnim){}
      }, 30);
    });
  });

  refresh(false);

  /* Re-refresh if classes change externally */
  var mo = new MutationObserver(function(){ refresh(false); });
  cards.forEach(function(c){ mo.observe(c, { attributes:true, attributeFilter:['class'] }); });

  /* ===== BUY NOW — trigger native form submission ===== */
  function triggerBuy(){
    /* Look for native buy-now or submit buttons in priority order */
    var sels = [
      'button[name="checkout"]',
      '[data-shopify="payment-button"] button',
      'shopify-payment-terms ~ button',
      'product-form button[type="submit"][name="add"]',
      'form[action*="/cart/add"] button[type="submit"]',
      'button[type="submit"][name="add"]'
    ];
    for (var i = 0; i < sels.length; i++){
      var btn = document.querySelector(sels[i]);
      if (btn && btn.offsetParent !== null){
        btn.click();
        return true;
      }
    }
    /* Fallback: submit the first product form */
    var form = document.querySelector('form[action*="/cart/add"]');
    if (form){
      form.submit();
      return true;
    }
    return false;
  }
  if (ctaBtn) ctaBtn.addEventListener('click', triggerBuy);
  if (sBuyBtn) sBuyBtn.addEventListener('click', triggerBuy);

  /* ===== Delivery timeline animation loop ===== */
  /* ===== Delivery timeline animation loop (ported verbatim from reference) ===== */
  (function initJourneyWrap(){
    var tlrow = root.querySelector('[data-fc-tlrow]');
    if (!tlrow) return;
    var truck = tlrow.querySelector('[data-fc-tltruck]');
    var fill = tlrow.querySelector('[data-fc-tlfill]');
    var base = tlrow.querySelector('[data-fc-tltrack]');
    var stops = tlrow.querySelectorAll('[data-fc-tlstop]');
    if (!truck || !fill || !base || stops.length !== 3) return;

    var cx = [], tmrs = [];
    function clearT(){ tmrs.forEach(clearTimeout); tmrs = []; }
    var LEG = 10000;

      /* Fill bar locked to truck position via rAF — fill is ALWAYS at the back of the truck */
      var fillRafActive = false;
      function syncFillToTruck(){
        if (!truck || !fill || !tlrow) return;
        try {
          var trow = tlrow.getBoundingClientRect();
          var trec = truck.getBoundingClientRect();
          /* Truck center relative to tlrow's left edge */
          var truckCenterX = (trec.left + trec.width / 2) - trow.left;
          /* Start of the track is cx[0] (Ordered stop's center) */
          var startX = cx && cx.length ? cx[0] : 0;
          var w = Math.max(0, truckCenterX - startX);
          fill.style.width = w + 'px';
        } catch(e){}
        requestAnimationFrame(syncFillToTruck);
      }
      if (!fillRafActive) {
        fillRafActive = true;
        requestAnimationFrame(syncFillToTruck);
      }

    function st(i, cls){
      var e = stops[i];
      if (!e) return;
      e.classList.remove('is-active','is-done');
      if (cls === 'on') e.classList.add('is-active');
      else if (cls === 'done') e.classList.add('is-done');
    }

    function initJourney(){
      var rb = tlrow.getBoundingClientRect();
      cx = [];
      for (var i = 0; i < 3; i++){
        var r = stops[i].getBoundingClientRect();
        cx.push(r.left + r.width/2 - rb.left);
      }
      base.style.left = cx[0] + 'px';
      base.style.width = (cx[2] - cx[0]) + 'px';
      fill.style.left = cx[0] + 'px';
      loopJourney();
    }

    function loopJourney(){
      clearT();

      /* HARD RESET - truck snaps to start; fill follows automatically via rAF on next frame */
      truck.style.transition = 'none';
      truck.style.left = cx[0] + 'px';
      st(0,'on'); st(1,''); st(2,'');
      void truck.offsetWidth;
      void fill.offsetWidth;
      truck.classList.add('is-bouncing');

      var LEG_MS = 14000;
      var FILL_DELAY = 250; /* kept for total-cycle timing; fill itself is rAF-driven */
      var PAUSE_START = 1000;
      var PAUSE_MID = 800;
      var PAUSE_END = 1800;

      /* LEG 1: Ordered -> Shipped */
      tmrs.push(setTimeout(function(){
        truck.style.transition = 'left ' + LEG_MS + 'ms cubic-bezier(.4,0,.4,1)';
        truck.style.left = cx[1] + 'px';
        tmrs.push(setTimeout(function(){ st(0,'done'); st(1,'on'); }, LEG_MS - 100));
      }, PAUSE_START));

      /* LEG 2: Shipped -> Delivered */
      tmrs.push(setTimeout(function(){
        truck.style.transition = 'left ' + LEG_MS + 'ms cubic-bezier(.4,0,.4,1)';
        truck.style.left = cx[2] + 'px';
        tmrs.push(setTimeout(function(){ st(1,'done'); st(2,'on'); }, LEG_MS - 100));
      }, PAUSE_START + LEG_MS + PAUSE_MID));

      /* LOOP RESTART - after last leg + fill catches up + end pause */
      tmrs.push(setTimeout(loopJourney, PAUSE_START + LEG_MS + PAUSE_MID + LEG_MS + FILL_DELAY + PAUSE_END));
    }

    if (document.readyState === 'complete'){
      setTimeout(initJourney, 300);
    } else {
      window.addEventListener('load', function(){ setTimeout(initJourney, 300); });
      setTimeout(initJourney, 1500);
    }
    window.addEventListener('resize', function(){ setTimeout(initJourney, 200); });
  })();

  /* Variant-aware social proof toast — mix of "X viewing" + "Name from City bought [variant]" */
      try {
        var fcVariantTitles = ["Default Title"];
      } catch(e){ var fcVariantTitles = ['this']; }
      var fcNames = ['Priya','Riya','Ananya','Meera','Sneha','Kavya','Pooja','Aditi','Neha','Shreya','Rahul','Vikram','Karan','Anand','Rohan','Aarav','Aditya','Arjun','Manoj','Suresh'];
      var fcCities = ['Delhi','Mumbai','Bangalore','Pune','Chennai','Hyderabad','Jaipur','Kolkata','Ahmedabad','Lucknow','Surat','Indore','Bhopal','Nagpur','Coimbatore'];
      function fcRandom(arr){ return arr[Math.floor(Math.random() * arr.length)]; }
      function fcBuildSocialMsg(){
        var roll = Math.random();
        if (roll < 0.35) {
          /* "X people viewing this right now" — 35% of messages */
          var viewers = Math.floor(Math.random() * 250) + 40; /* 40-289 */
          return viewers + ' people viewing this right now';
        } else {
          /* "Name from City bought VARIANT" — 65% of messages */
          var name = fcRandom(fcNames);
          var city = fcRandom(fcCities);
          var variant = fcRandom(fcVariantTitles);
          /* Clean variant title — strip stuff after " - " or "-NNNRs" patterns */
          var cleanV = variant.split(' - ')[0].split(' -')[0].trim();
          return name + ' from ' + city + ' bought ' + cleanV;
        }
      }
      if (toast && toastTx){
        toastTx.textContent = fcBuildSocialMsg();
        setInterval(function(){
          if (!toast || !toastTx) return;
          toast.style.opacity = '0';
          setTimeout(function(){
            toastTx.textContent = fcBuildSocialMsg();
            toast.style.opacity = '1';
          }, 400);
        }, 3500);
      }

      /* Reorder: move delivery + trust + toast to AFTER the theme's native buy_buttons block */
      function fcReorderAttempt(attemptsLeft){
        try {
          var delivery = root.querySelector('[data-fc-tlrow]');
          var trustRow = root.querySelector('.fcpack__trustrow');
          var toast = root.querySelector('[data-fc-toast]') || root.querySelector('.fcpack__toast');
          var delContainer = delivery ? delivery.closest('.fcpack__delivery') : null;

          /* Selector list - actual classes from buy-buttons.liquid (Shrine Theme Pro) first, then generic fallbacks */
          var selectors = [
            /* Shrine/Flying Carts specific - the real BUY NOW button + shiprocket container */
            '.shiprocket-headless[data-type="product"]',
            'button.atc-button.main-product-atc',
            'button.main-product-atc',
            '[id^="ProductSubmitButton-"]',
            '[id^="SectionAtcBtn-"]',
            'product-form.main-product-form .product-form__buttons',
            'product-form#ProductForm-' + (window.SECTION_ID || ''),
            'product-form.main-product-form',
            /* Generic theme fallbacks */
            '.product-form__buttons',
            'product-form',
            'button[name="add"]',
            '.shopify-payment-button',
            '.product__buy-buttons'
          ];

          var buyBlock = null;
          var matchedSel = null;
          for (var i = 0; i < selectors.length; i++){
            var el = document.querySelector(selectors[i]);
            if (el) {
              buyBlock = el.closest('.shopify-block, [data-block-id], [data-shopify-block-id], product-form, .product-form, .product__buy-buttons') || el.parentElement;
              matchedSel = selectors[i];
              break;
            }
          }

          /* Final fallback: scan visible buttons/links for "BUY NOW" or "ADD TO CART" text */
          if (!buyBlock){
            var allButtons = document.querySelectorAll('button, a.button, a.btn, [role="button"]');
            var ourBuy = root.querySelector('[data-fc-buy]');
            for (var k = 0; k < allButtons.length; k++){
              var btn = allButtons[k];
              if (btn === ourBuy || (ourBuy && ourBuy.contains(btn))) continue;
              if (root.contains(btn)) continue; /* skip anything inside our own snippet */
              var txt = (btn.textContent || '').trim().toUpperCase();
              if ((txt.indexOf('BUY NOW') !== -1 || txt.indexOf('ADD TO CART') !== -1) && btn.offsetParent !== null){
                buyBlock = btn.closest('.shopify-block, [data-block-id], [data-shopify-block-id], product-form, .product-form, .product__buy-buttons') || btn.parentElement;
                matchedSel = 'text-content-fallback: ' + txt.substring(0, 20);
                break;
              }
            }
          }

          if (buyBlock && buyBlock.parentNode){
            console.log('[fcpack] Reorder matched selector:', matchedSel, buyBlock);
            var anchor = buyBlock;
            if (delContainer) {
              buyBlock.parentNode.insertBefore(delContainer, anchor.nextSibling);
              anchor = delContainer;
            }
            if (trustRow) {
              buyBlock.parentNode.insertBefore(trustRow, anchor.nextSibling);
              anchor = trustRow;
            }
            if (toast) {
              buyBlock.parentNode.insertBefore(toast, anchor.nextSibling);
              anchor = toast;
            }
            root.setAttribute('data-fc-reordered', '1');
            return true;
          } else {
            console.log('[fcpack] Reorder: no buy block found yet, attemptsLeft=', attemptsLeft);
            if (attemptsLeft > 0){
              setTimeout(function(){ fcReorderAttempt(attemptsLeft - 1); }, 500);
            }
          }
        } catch(eR){
          console.log('[fcpack] Reorder error:', eR);
          if (attemptsLeft > 0){
            setTimeout(function(){ fcReorderAttempt(attemptsLeft - 1); }, 500);
          }
        }
      }

      /* Kick off reorder: try immediately, on load, and a few times after */
      function fcReorderKick(){
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){
            fcReorderAttempt(10);
          });
        });
      }
      if (document.readyState === 'complete'){
        fcReorderKick();
      } else {
        window.addEventListener('load', fcReorderKick);
        setTimeout(fcReorderKick, 1500);
      }

      /* Show sticky bar only when the theme's main BUY NOW scrolls out of view */
      (function initStickyScroll(){
        var stickyBar = root.querySelector('[data-fc-sticky]') || root.querySelector('.fcpack-sticky') || document.querySelector('[data-fc-sticky]') || document.querySelector('.fcpack-sticky');
        if (!stickyBar) return;
        stickyBar.style.transition = 'transform .3s ease, opacity .3s ease';
        stickyBar.style.transform = 'translateY(100%)';
        stickyBar.style.opacity = '0';
        var mainBuy = document.querySelector('.shiprocket-headless[data-type="product"]')
                   || document.querySelector('button.atc-button.main-product-atc')
                   || document.querySelector('button.main-product-atc')
                   || document.querySelector('[id^="ProductSubmitButton-"]')
                   || document.querySelector('button[name="add"]')
                   || document.querySelector('.shopify-payment-button')
                   || document.querySelector('.product__buy-buttons');
        if (!mainBuy) return;
        if (!('IntersectionObserver' in window)) {
          window.addEventListener('scroll', function once(){
            stickyBar.style.transform = 'translateY(100%)';
            stickyBar.style.opacity = '1';
          });
          return;
        }
        var observer = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if (e.isIntersecting) {
              /* Main buy is visible — hide sticky */
              stickyBar.style.transform = 'translateY(100%)';
              stickyBar.style.opacity = '1';
            } else {
              /* Main buy is out of view — show sticky */
              stickyBar.style.transform = 'translateY(0)';
              stickyBar.style.opacity = '1';
            }
          });
        }, { showall: true });
        observer.observe(mainBuy);
      })();

})();
</script>



