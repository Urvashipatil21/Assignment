}

  /* B. Smaller product title */
  .product__title, h1.product__title, .product__title h1,
  .product-info__title, .product__info-container h1 {
    font-size: 22px !important;
    line-height: 1.2 !important;
    letter-spacing: -0.01em !important;
    margin-bottom: 6px !important;
  }

  /* C. Variant cards: collapse right-column 3-stack to compact 2-row */
  .fcpack__card { padding: 10px 12px !important; gap: 8px !important; }
  .fcpack__name { font-size: 13.5px !important; line-height: 1.2 !important; }
  .fcpack__sub { font-size: 11px !important; line-height: 1.3 !important; margin-top: 2px !important; }
  .fcpack__sub--mute, .fcpack__sub--save { font-size: 11px !important; }
  .fcpack__priceright, .fcpack__card .fcpack__price, .fcpack__card .fcpack__priceright {
