</sticky-atc>
<script>
(function(){
  var SECTION_ID = 'template--24445711319063__main';
  
  function syncStickyPrice(){
    /* Use our snippet's main price element as source of truth */
    var src = document.querySelector('[data-fc-main-price]');
    if (!src) return;
    var txt = src.textContent.trim();
    if (!txt) return;
    
    /* Update the separate price block */
    var priceBlock = document.getElementById('sticky-atc-separate-price-' + SECTION_ID);
    if (priceBlock) {
      var items = priceBlock.querySelectorAll('.price-item--sale, .price-item--regular, .price-item');
      items.forEach(function(el){ el.textContent = txt; });
    }
    
    /* Update price-in-button span if used */
    var btnSpans = document.querySelectorAll('.main-atc-price-span-' + SECTION_ID);
    btnSpans.forEach(function(el){ el.textContent = txt; });
  }
  
  function init(){
    var src = document.querySelector('[data-fc-main-price]');
    if (!src) { setTimeout(init, 500); return; }
    
    /* Watch the main price element for any text change */
    var mo = new MutationObserver(syncStickyPrice);
    mo.observe(src, { childList: true, characterData: true, subtree: true });
    
    /* Backup: listen for variant input change */
    document.addEventListener('change', function(e){
      if (e.target && e.target.name === 'id') setTimeout(syncStickyPrice, 100);
    });
    
    /* Backup: listen for variant card clicks (our fcpack__card) */
    document.addEventListener('click', function(e){
      if (e.target.closest && e.target.closest('[data-fc-card]')) {
        setTimeout(syncStickyPrice, 150);
      }
    });
    
    syncStickyPrice();
  }
  
  if (document.readyState === 'complete') init();
  else window.addEventListener('load', init);
  setTimeout(init, 1500);
})();
</script>
<script>
(function(){
  var SECTION_ID = 'template--24445711319063__main';
  var stickyBar = document.getElementById('sticky-atc-' + SECTION_ID);
  if (!stickyBar) return;
  
  function findMainBuy(){
    /* Main BUY NOW — exclude the one INSIDE the sticky bar (has .stkrextra class) */
    var candidates = [
      '.shiprocket-headless[data-type="product"]:not(.stkrextra)',
      'button.atc-button.main-product-atc:not(.sticky-atc__add_button)',
      '[id^="ProductSubmitButton-"]',
      'button[name="add"]:not(.sticky-atc__add_button)'
    ];
    for (var i = 0; i < candidates.length; i++) {
      var el = document.querySelector(candidates[i]);
      if (el && el.offsetParent !== null) return el;
    }
    return null;
  }
  
  function init(){
    var mainBuy = findMainBuy();
    if (!mainBuy) { setTimeout(init, 500); return; }
    
    /* Start hidden */
    stickyBar.style.transition = 'transform .3s ease, opacity .3s ease';
    stickyBar.style.transform = 'translateY(100%)';
    stickyBar.style.opacity = '0';
    stickyBar.style.pointerEvents = 'none';
    
    if (!('IntersectionObserver' in window)) {
      /* Fallback: just show */
      stickyBar.style.transform = 'translateY(0)';
      stickyBar.style.opacity = '1';
      stickyBar.style.pointerEvents = 'auto';
      return;
    }
    
    var observer = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        var rect = e.boundingClientRect;
        /* Show only when main BUY NOW is ABOVE the viewport (user scrolled past it) */
        if (!e.isIntersecting && rect.top < 0) {
          stickyBar.style.transform = 'translateY(0)';
          stickyBar.style.opacity = '1';
          stickyBar.style.pointerEvents = 'auto';
        } else {
          /* Main BUY NOW is visible OR still below viewport — hide */
          stickyBar.style.transform = 'translateY(100%)';
          stickyBar.style.opacity = '0';
          stickyBar.style.pointerEvents = 'none';
        }
      });
    }, { threshold: 0, rootMargin: '0px' });
    
    observer.observe(mainBuy);
  }
  
  if (document.readyState === 'complete') init();
  else window.addEventListener('load', init);
  setTimeout(init, 1500);
  setTimeout(init, 3500);
})();
</script>

